{
  "name": "wilds",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:worker\"",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "wrangler deploy",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "partyserver": "^0.1.5"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tsconfig/svelte": "^5.0.6",
    "@types/node": "^24.10.1",
    "concurrently": "^9.2.1",
    "svelte": "^5.45.2",
    "svelte-check": "^4.3.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "wrangler": "^4.66.0"
  }
}
